# SynAI — Configurações de API
# Copie para .env e preencha apenas os providers que você usa.

# ── Tier 1: Premium ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=       # Claude 3.5/4 — https://console.anthropic.com
OPENAI_API_KEY=          # GPT-4o — https://platform.openai.com

# ── Tier 2: Alto Valor / Custo-Benefício ─────────────────────────────────────
DEEPSEEK_API_KEY=        # DeepSeek V3 / R1 — https://platform.deepseek.com
XAI_API_KEY=             # Grok 3 — https://console.x.ai

# ── Tier 3: Gateway / Ecossistema Open-Source ────────────────────────────────
OPENROUTER_API_KEY=      # 300+ modelos (Qwen, Mistral, Llama) — https://openrouter.ai
GROQ_API_KEY=            # Llama/Mixtral ultra-rápido — https://console.groq.com

# ── Tier 4: Local / Soberano ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434   # Ollama local (default)

# ── Google ───────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=          # Gemini Flash/Pro — https://aistudio.google.com
