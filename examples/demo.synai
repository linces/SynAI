// SynAI v1.6 — Demo: Pipeline Multi-Provider com Model Profiles
//
// Este workflow demonstra:
//   1. Uso de model profiles semânticos ("best-reasoner", "best-coder")
//   2. Uso de modelo específico via nome amigável ("deepseek-reasoner")
//   3. Uso de "auto" — SynAI decide o melhor provider disponível
//   4. Agente TOOL (ferramenta local Python)
//   5. Conexão assíncrona entre agentes com timeout
//
// Para executar:
//   synai build examples/demo.synai -o out/demo.synx
//   synai run out/demo.synx --real

orchestrator "AICodeReview" {

  agents {

    // Busca o código a revisar usando ferramenta local
    fetcher: TOOL {
      function: "read_file"
    }

    // Analista usa o melhor modelo de raciocínio disponível
    analyst: LLM {
      model: "best-reasoner"
      capabilities: ["reason", "analyze", "critique"]
    }

    // Gerador de código usa o melhor modelo de código disponível
    coder: LLM {
      model: "best-coder"
      capabilities: ["code", "generate", "refactor"]
    }

    // Sumarizador usa qualquer modelo rápido disponível
    summarizer: LLM {
      model: "best-fast"
      capabilities: ["summarize", "format"]
    }

  }

  workflow "ReviewAndImprove" {

    // Etapa 1: Ler o arquivo de código
    intent "Ler Código" {
      agent: fetcher
      input: "src/main.py"
    }

    // Passar código para análise
    connect fetcher.output -> analyst.input { async: false }

    // Etapa 2: Análise crítica do código
    intent "Analisar Código" {
      agent: analyst
      input: result("Ler Código")
    }

    // Passar análise para o gerador (com retry em caso de falha)
    connect analyst.output -> coder.input { async: true timeout: 60s retry: 2 }

    // Etapa 3: Gerar código melhorado
    intent "Refatorar" {
      agent: coder
      input: result("Analisar Código")
    }

    // Passar resultado para sumarização
    connect coder.output -> summarizer.input { async: false timeout: 30s }

    // Etapa 4: Gerar relatório final
    intent "Relatório Final" {
      agent: summarizer
      input: result("Refatorar")
    }

  }

}

run "AICodeReview" with workflow "ReviewAndImprove"